{
  "name": "dms-rb",
  "version": "2.0.0",
  "description": "DMS Proto — unified React Bootstrap client and Node.js backend",
  "main": "server/index.js",
  "scripts": {
    "install:all": "npm install && npm install --prefix client",
    "install:client": "npm install --prefix client",
    "build": "npm run build --prefix client",
    "start": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "setup": "npm run install:all && npm run build",
    "postinstall": "echo \"\\nRun 'npm run setup' for first-time setup or 'npm run dev' for development\\n\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
